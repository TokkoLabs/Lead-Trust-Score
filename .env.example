# .env.example — Lead Trust Copilot
# Copia este archivo a .env en la raíz del repo y completa los valores.
# El archivo .env NUNCA debe commitearse (está en .gitignore).

# ── Requerido ────────────────────────────────────────────────────────────────
# Clave de API de Anthropic. Necesaria para el scoring de leads con Claude.
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Arnés R2D2 ────────────────────────────────────────────────────────────────
# Login de GitHub esperado, usado por init.sh para validar el entorno.
GITHUB_EXPECTED_USER=your-github-username

# ── Opcional ─────────────────────────────────────────────────────────────────
# NODE_ENV: el Dockerfile lo fija en production; no es necesario cambiarlo.
# NODE_ENV=production

# APP_PORT: puerto host para los servicios del arnés (perfil product).
APP_PORT=8080
